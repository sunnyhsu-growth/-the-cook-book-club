# ─── Server (Express) — keep these SECRET, never expose to the client ───
PORT=3001
CLIENT_URL=http://localhost:5173

# Supabase (server uses the service-role key so it can write regardless of RLS,
# or the anon key if you prefer RLS to apply server-side too)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Anthropic — the recipe extraction key. SERVER ONLY.
ANTHROPIC_API_KEY=sk-ant-...
# Model used for photo/text -> structured recipe extraction.
# claude-opus-4-8 = maximum accuracy on messy handwriting.
# Switch to claude-sonnet-4-6 for a cheaper cost/quality balance.
CLAUDE_MODEL=claude-opus-4-8
